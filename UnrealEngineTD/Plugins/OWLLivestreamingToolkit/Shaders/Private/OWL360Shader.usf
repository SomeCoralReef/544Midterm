#if USE_DEBUG_COLORS
    static const float3 debugColors[6] = {
       float3(1.0, 0.0, 0.0),    // Pure red
       float3(0.0, 1.0, 0.0),    // Pure green
       float3(0.0, 0.0, 1.0),    // Pure blue
       float3(1.0, 1.0, 0.0),    // Yellow
       float3(1.0, 0.0, 1.0),    // Magenta
       float3(0.0, 1.0, 1.0)    // Cyan
    };
